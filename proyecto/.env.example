# ─────────────────────────────────────────────────────────────────
# ConstructCompare Backend — Variables de entorno
# Copia este archivo como .env y rellena los valores reales
# ─────────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
# Ejemplo local con Docker: postgresql://postgres:password@localhost:5432/constructcompare
# Ejemplo Neon: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/constructcompare"

# Puerto del servidor (default: 3000)
PORT=3000

# Orígenes permitidos por CORS
# Para desarrollo: * (todos) o http://localhost:5500 (Live Server)
# Para producción: tu dominio real
CORS_ORIGIN=*

# ─────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
# 1. Renombra este archivo a .env
# 2. Modifica DATABASE_URL con tu conexión real
# 3. Ejecuta: npm run dev
# ─────────────────────────────────────────────────────────────────
